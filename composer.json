{
  "name": "wugweb/icube",
  "description": "ICube - WordPress Website",
  "type": "project",
  "require": {
    "php": ">=8.0",
    "composer/installers": "^2.2",
    "johnpbloch/wordpress": "^6.5"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.0 || ^10.0",
    "wp-cli/wp-cli": "^2.8"
  },
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "WugWeb",
      "email": "info@wugweb.com"
    }
  ],
  "config": {
    "allow-plugins": {
      "composer/installers": true,
      "johnpbloch/wordpress-core-installer": true
    }
  },
  "extra": {
    "wordpress-install-dir": "wordpress",
    "installer-paths": {
      "wp-content/plugins/{$name}/": [
        "type:wordpress-plugin"
      ],
      "wp-content/themes/{$name}/": [
        "type:wordpress-theme"
      ]
    }
  },
  "scripts": {
    "test": "phpunit",
    "post-install-cmd": [],
    "post-update-cmd": []
  },
  "autoload": {
    "psr-4": {
      "ICube\\": "wp-content/plugins/icube-custom/src/",
      "ICubeTheme\\": "wp-content/themes/icube-custom/src/"
    },
    "files": [
      "wp-content/mu-plugins/autoloader.php"
    ]
  }
}
